{
  "name": "git-truck",
  "version": "3.1.1",
  "private": false,
  "description": "Visualizing a Git repository",
  "license": "MIT",
  "main": "./cli.mjs",
  "bin": "./cli.mjs",
  "files": [
    "LICENSE",
    "README.md",
    "build/",
    "public/",
    "cli.mjs"
  ],
  "type": "module",
  "scripts": {
    "test": "npm run test:e2e && npm run test:unit",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest watch",
    "test:e2e": "npx playwright test",
    "test:e2e:headed": "npx playwright test --headed",
    "pretest:e2e": "npm run build",
    "pretest:e2e:headed": "npm run build",
    "build": "cross-env NODE_ENV=production npm run build-vite && npm run build-cli",
    "build:dev": "cross-env NODE_ENV=development npm run build-vite && npm run build-cli",
    "build-cli": "cross-env NODE_ENV=production tsdown",
    "build-vite": "react-router build",
    "dev": "cross-env NODE_ENV=development ./src/cli.ts",
    "dev:bun": "cross-env NODE_ENV=development bun ./src/cli.ts",
    "dev:verbose": "cross-env NODE_ENV=development tsx ./src/cli.ts --log debug",
    "start": "cross-env NODE_ENV=production node .",
    "clean": "npx -y rimraf build .react-router .cache .temp cli.js cli.cjs",
    "typecheck": "react-router typegen && tsc -b",
    "typegen:watch": "react-router typegen --watch",
    "pub-pre": "npm version prerelease && npm publish --tag next",
    "pub-premajor": "npm version premajor && npm publish --tag next",
    "pub-preminor": "npm version preminor && npm publish --tag next",
    "pub-prepatch": "npm version prepatch && npm publish --tag next",
    "pub-exp": "node ./scripts/publish-experimental",
    "prepublishOnly": "npm run clean && npm run build",
    "format:write": "prettier --log-level warn --write src scripts e2e",
    "lint:fix": "eslint --fix --cache",
    "check:write": "npm run knip:write && npm run lint:fix && npm run format:write",
    "check": "npm run knip && npm run lint && npm run format:check",
    "format:check": "prettier --check src scripts e2e",
    "lint": "eslint --cache",
    "prepare": "node .husky/install.mjs",
    "update-deps": "npx npm-check-updates -i",
    "knip": "knip",
    "knip:write": "knip --fix"
  },
  "dependencies": {
    "@duckdb/node-api": "^1.4.2-r.1",
    "@headlessui/react": "^2.2.9",
    "@mdi/js": "^7.4.47",
    "@react-router/express": "^7.13.0",
    "a11y-contrast-color": "^1.1.0",
    "ansi-colors": "^4.1.3",
    "byte-size": "^9.0.1",
    "clsx": "^2.1.1",
    "color-convert": "^3.1.3",
    "d3": "^7.9.0",
    "ignore": "^7.0.5",
    "nanospinner": "^1.2.2",
    "nuqs": "^2.8.8",
    "randomstring": "^1.3.1",
    "react-colorful": "^5.6.1",
    "react-compound-slider": "^3.4.0",
    "react-datepicker": "^8.10.0",
    "react-tiny-popover": "^8.1.6",
    "semver": "^7.7.4",
    "sha1": "^1.1.1",
    "tailwind-merge": "^3.4.0",
    "yargs-parser": "^22.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.58.2",
    "@react-router/dev": "^7.13.0",
    "@react-router/fs-routes": "^7.13.0",
    "@react-router/node": "^7.13.0",
    "@tailwindcss/vite": "^4.1.18",
    "@types/byte-size": "^8.1.2",
    "@types/d3": "^7.4.3",
    "@types/d3-hierarchy": "^3.1.7",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.0",
    "@types/randomstring": "^1.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/semver": "^7.7.1",
    "@types/sha1": "^1.1.5",
    "@types/yargs-parser": "^21.0.3",
    "cross-env": "^10.1.0",
    "d3-hierarchy": "^3.1.2",
    "dotenv": "^17.2.4",
    "eslint": "^9.39.2",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "express": "^5.2.1",
    "get-port": "^7.1.0",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "isbot": "^5.1.35",
    "knip": "^5.83.1",
    "language-map": "^1.5.0",
    "lint-staged": "^16.2.7",
    "npm-check-updates": "^19.3.2",
    "open": "^11.0.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "^7.13.0",
    "react-router-devtools": "^6.2.0",
    "react-use-size": "^5.0.1",
    "tailwindcss": "^4.1.18",
    "tsdown": "^0.16.8",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.55.0",
    "vite": "npm:rolldown-vite@7.3.1",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18"
  },
  "tsdown": {
    "entry": "./src/cli.ts",
    "outDir": ".",
    "treeshake": true,
    "clean": false,
    "external": [
      "vite",
      "lightningcss"
    ],
    "cjs-interop": true,
    "env": {
      "NODE_ENV": "production"
    }
  },
  "prettier": {
    "semi": false,
    "printWidth": 120,
    "trailingComma": "none",
    "endOfLine": "lf",
    "plugins": [
      "prettier-plugin-tailwindcss"
    ]
  },
  "lint-staged": {
    "{src,scripts}/**/*.{ts,tsx,js,mjs}": [
      "eslint --cache --fix",
      "prettier --write"
    ]
  },
  "knip": {
    "entry": [
      "src/server/app.ts",
      "src/routes/**/*.tsx",
      "scripts/**/*.{ts,js}"
    ]
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/git-truck/git-truck.git"
  },
  "bugs": {
    "url": "https://github.com/git-truck/git-truck/issues"
  },
  "homepage": "https://github.com/git-truck/git-truck#readme"
}
