{
  "extends": "./tsconfig.json",
  "include": [
    "src/server/**/*",
    "src/shared/**/*",
    "scripts/**/*",
    "src/**/*.server.ts",
    "src/cli.ts",
    "vite.config.ts",
    "react-router.config.ts",
  ],
  "compilerOptions": {
    "composite": true,
    "lib": ["esnext", "esnext.disposable"],
    "types": ["node"],
    "module": "ESNext",
    "moduleResolution": "bundler"
  }
}
