{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start dev server with bun",
      "type": "process",
      "command": "bun",
      "args": ["dev"],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "runOptions": {
        "runOn": "folderOpen"
      },
      "dependsOn": ["Install dependencies with bun"],
      "problemMatcher": []
    },
    {
      "label": "Install dependencies with bun",
      "type": "process",
      "command": "bun",
      "args": ["install"],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "Build with bun",
      "type": "process",
      "command": "bun",
      "group": "build",
      "args": ["run", "build"],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "Build with bun (development)",
      "type": "process",
      "command": "bun",
      "group": "build",
      "args": ["run", "build:dev"],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "Typecheck with bun",
      "type": "shell",
      "command": "bun",
      "args": ["typecheck"],
      "problemMatcher": ["$tsc"],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    }
  ]
}
