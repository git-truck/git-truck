{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start dev server with bun on folder open",
      "type": "shell",
      "command": "bun --bun dev:bun",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "runOptions": {
        "runOn": "folderOpen"
      }
    }
  ]
}
